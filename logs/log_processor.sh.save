#!/bin/bash

FILE="server.log"

echo "----Starting Live Log Processing-----"

while read -r LINE; do
  
    if echo "$LINE" | grep -qE "CrashLoopBackOff|Timeout"; then
      echo "Critical Error Detected: $LINE"

    else
       echo "Detail Info  $LINE"

    fi 

done < "$FILE"

echo " -----Log Processing Complete------ "
